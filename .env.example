# Скопируйте в .env (файл .env в git не попадает)

# Обязательно на Railway / production
SECRET_KEY=замените_на_случайную_строку_64_символа

# Веб (локально можно не задавать)
FLASK_DEBUG=true
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
CORS_ORIGINS=http://127.0.0.1:5000,http://localhost:5000

# Синхронизация
SYNC_SERVER_URL=https://your-sync-server.up.railway.app

# sync_server (ravishing-caring): разрешить веб-приложение
# CORS_ORIGINS=http://127.0.0.1:5000,http://localhost:5000,https://family-tree-production-0e7d.up.railway.app
DATA_DIR=data

# Скрипты загрузки (не коммитить реальные значения)
# FAMILY_TREE_LOGIN=
# FAMILY_TREE_PASSWORD=
